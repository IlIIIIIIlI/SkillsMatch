{
  "name": "skillmatch",
  "displayName": "SkillMatch",
  "description": "Discover, classify, and visualize local, workspace, and online AI skills from one VS Code sidebar.",
  "version": "0.0.1",
  "publisher": "chenoilab",
  "private": true,
  "icon": "media/skill-map-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IlIIIIIIlI/SkillsMatch.git"
  },
  "homepage": "https://github.com/IlIIIIIIlI/SkillsMatch",
  "bugs": {
    "url": "https://github.com/IlIIIIIIlI/SkillsMatch/issues"
  },
  "keywords": [
    "skills",
    "agents",
    "openrouter",
    "lightrag",
    "visualization",
    "sidebar"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onView:skillMap.explorer",
    "onView:skillMap.explorerInline",
    "onView:skillMap.overview",
    "onCommand:skillMap.refresh",
    "onCommand:skillMap.configureOpenRouterKey",
    "onCommand:skillMap.generateTags",
    "onCommand:skillMap.openDashboard",
    "onCommand:skillMap.configureGitHubSources",
    "onCommand:skillMap.configureLightRagBaseUrl",
    "onCommand:skillMap.syncKnowledgeBase",
    "onCommand:skillMap.applyRecommendedSkills"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "skillMap.refresh",
        "title": "SkillMatch: Refresh Catalog"
      },
      {
        "command": "skillMap.configureOpenRouterKey",
        "title": "SkillMatch: Configure OpenRouter API Key"
      },
      {
        "command": "skillMap.openOpenRouterSettings",
        "title": "SkillMatch: Open OpenRouter Settings"
      },
      {
        "command": "skillMap.configureLightRagBaseUrl",
        "title": "SkillMatch: Configure LightRAG Base URL"
      },
      {
        "command": "skillMap.configureGitHubSources",
        "title": "SkillMatch: Configure GitHub Skill Sources"
      },
      {
        "command": "skillMap.clearOpenRouterKey",
        "title": "SkillMatch: Clear OpenRouter API Key"
      },
      {
        "command": "skillMap.generateTags",
        "title": "SkillMatch: Generate AI Tags"
      },
      {
        "command": "skillMap.syncKnowledgeBase",
        "title": "SkillMatch: Sync LightRAG Knowledge Base"
      },
      {
        "command": "skillMap.applyRecommendedSkills",
        "title": "SkillMatch: Apply Recommended Skills To Project"
      },
      {
        "command": "skillMap.openSkill",
        "title": "SkillMatch: Open Skill"
      },
      {
        "command": "skillMap.setFilter",
        "title": "SkillMatch: Set Filter"
      },
      {
        "command": "skillMap.clearFilter",
        "title": "SkillMatch: Clear Filter"
      },
      {
        "command": "skillMap.openDashboard",
        "title": "SkillMatch: Open Dashboard",
        "icon": "media/open-dashboard.svg"
      }
    ],
    "configuration": {
      "title": "SkillMatch",
      "properties": {
        "skillMap.openRouter.baseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "Base URL for the OpenRouter-compatible chat completions endpoint."
        },
        "skillMap.openRouter.model": {
          "type": "string",
          "default": "openai/gpt-4.1-mini",
          "description": "OpenRouter model used for AI tag enrichment and skill recommendation."
        },
        "skillMap.openRouter.autoGenerateTagsOnRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically enrich uncached skills when an OpenRouter API key is configured."
        },
        "skillMap.openRouter.batchSize": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 25,
          "description": "Number of skills sent in a single OpenRouter enrichment request."
        },
        "skillMap.openRouter.maxSkillsPerRun": {
          "type": "number",
          "default": 24,
          "minimum": 1,
          "maximum": 500,
          "description": "Maximum number of skills processed in one Generate AI Tags run."
        },
        "skillMap.openRouter.requestDelayMs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 10000,
          "description": "Delay in milliseconds inserted between OpenRouter tag-generation batches."
        },
        "skillMap.openRouter.tagPrompt": {
          "type": "string",
          "default": "",
          "description": "Additional instructions appended to the built-in SkillMatch tag-generation prompt."
        },
        "skillMap.scan.additionalGlobalPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional absolute paths to scan for global skills."
        },
        "skillMap.onlineSources.timeoutMs": {
          "type": "number",
          "default": 12000,
          "minimum": 3000,
          "maximum": 60000,
          "description": "Network timeout for fetching online skills."
        },
        "skillMap.onlineSources.githubUrls": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "GitHub repository, folder, or direct SKILL.md URLs to scan for online skills."
        },
        "skillMap.lightRag.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:9621",
          "description": "Base URL for the LightRAG API server used to build the skills knowledge base."
        },
        "skillMap.lightRag.autoSyncOnRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically sync the current skills catalog into LightRAG after each refresh."
        },
        "skillMap.lightRag.syncTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 10000,
          "maximum": 600000,
          "description": "Maximum time to wait for LightRAG indexing to finish."
        },
        "skillMap.project.applyRelativePath": {
          "type": "string",
          "default": ".codex/skills/skillmatch-curated",
          "description": "Workspace-relative path where recommended skills are copied into the current project."
        },
        "skillMap.visualization.maxTags": {
          "type": "number",
          "default": 36,
          "minimum": 8,
          "maximum": 80,
          "description": "Maximum number of tags to render in the overlap visualization."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillMap",
          "title": "SkillMatch",
          "icon": "media/activitybar.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "skillMap.explorerInline",
          "name": "SkillMatch"
        }
      ],
      "skillMap": [
        {
          "id": "skillMap.explorer",
          "name": "Explorer"
        },
        {
          "id": "skillMap.overview",
          "name": "Overview",
          "type": "webview",
          "when": "!skillMap.dashboardOpen"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "skillMap.refresh",
          "when": "view == skillMap.explorer",
          "group": "navigation"
        },
        {
          "command": "skillMap.configureOpenRouterKey",
          "when": "view == skillMap.explorer",
          "group": "navigation@1"
        },
        {
          "command": "skillMap.generateTags",
          "when": "view == skillMap.overview",
          "group": "navigation"
        },
        {
          "command": "skillMap.openDashboard",
          "when": "view == skillMap.explorerInline",
          "group": "navigation"
        },
        {
          "command": "skillMap.openDashboard",
          "when": "view == skillMap.overview",
          "group": "navigation@0"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf dist out .vscode-test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --noEmit -p tsconfig.json --watch",
    "watch": "npm-run-all -p watch:*",
    "compile": "npm run typecheck && node esbuild.mjs",
    "package": "npm run typecheck && node esbuild.mjs --production",
    "vscode:prepublish": "npm run package",
    "compile-tests": "tsc -p tsconfig.test.json",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out/test/runTest.js",
    "dev:vscode": "npm run compile && bash ./scripts/launch-vscode-dev.sh",
    "scan:trivy": "trivy fs --scanners vuln,secret,misconfig --ignore-unfixed .",
    "scan:clamav": "bash ./scripts/clamav-scan.sh"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.57",
    "@types/three": "^0.183.1",
    "@types/vscode": "1.95.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.10",
    "glob": "^11.0.3",
    "mocha": "^11.7.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "three": "^0.183.2"
  }
}
