{
  "version": "2.0.0",
  "problemMatchers": [
    {
      "name": "skill-map-esbuild-watch",
      "label": "skill-map-esbuild-watch",
      "owner": "typescript",
      "fileLocation": [
        "relative",
        "${workspaceFolder}"
      ],
      "pattern": [
        {
          "regexp": "^✘ \\[ERROR\\] (.+)$",
          "message": 1
        },
        {
          "regexp": "^\\s+(.+):(\\d+):(\\d+)$",
          "file": 1,
          "line": 2,
          "column": 3
        }
      ],
      "background": {
        "activeOnStart": true,
        "beginsPattern": "^\\[watch\\] .* started$",
        "endsPattern": "^\\[watch\\] .* finished$"
      }
    }
  ],
  "tasks": [
    {
      "label": "watch",
      "dependsOn": [
        "npm: watch:esbuild",
        "npm: watch:tsc"
      ],
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch:esbuild",
      "label": "npm: watch:esbuild",
      "group": "build",
      "problemMatcher": "$skill-map-esbuild-watch",
      "isBackground": true,
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    },
    {
      "type": "npm",
      "script": "watch:tsc",
      "label": "npm: watch:tsc",
      "group": "build",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "group": "watch",
        "reveal": "never"
      }
    }
  ]
}
